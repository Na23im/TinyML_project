  {
    "id": "reset_function",
    "type": "function",
    "z": "tab_composants",
    "name": "Reset tous compteurs",
    "func": "// Remet à zéro les contextes de tous les noeuds compteurs\nvar nodes = ['counter_led','counter_resistance','counter_condensateur','counter_ci'];\nnodes.forEach(function(n) {\n    flow.set(n + '_count', 0);\n});\n\n// Envoie 0 à tous les gauges\nvar msgs = [];\n['LED','Resistance','Condensateur','CircuitIntegre'].forEach(function(label) {\n    msgs.push({payload: 0, topic: label});\n});\nreturn [msgs[0], msgs[1], msgs[2], msgs[3]];",
    "outputs": 4,
    "x": 350,
    "y": 200,
    "wires": [["gauge_led"],["gauge_resistance"],["gauge_condensateur"],["gauge_ci"]]
  },
