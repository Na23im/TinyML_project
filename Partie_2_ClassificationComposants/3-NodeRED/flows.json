[
  {
    "id": "tab_composants",
    "type": "tab",
    "label": "Classification Composants",
    "disabled": false,
    "info": "Flow pour recevoir la classe détectée depuis Arduino (BLE via Serial) et incrémenter les compteurs."
  },
  {
    "id": "serial_in",
    "type": "serial in",
    "z": "tab_composants",
    "name": "Arduino Serial",
    "serial": "serial_config",
    "x": 130,
    "y": 100,
    "wires": [["parse_label"]]
  },
  {
    "id": "serial_config",
    "type": "serial-port",
    "serialport": "/dev/ttyACM0",
    "serialbaud": "115200",
    "databits": "8",
    "parity": "none",
    "stopbits": "1",
    "waitfor": "",
    "newline": "\\n",
    "bin": "false",
    "out": "char",
    "addchar": "",
    "responsetimeout": "10000"
  },
  {
    "id": "parse_label",
    "type": "function",
    "z": "tab_composants",
    "name": "Extraire la classe",
    "func": "// Le message Arduino est du type : \">> CLASSE DETECTEE : LED\"\nvar txt = msg.payload.toString().trim();\n\n// On cherche la ligne qui contient la classe détectée\nif (txt.indexOf('CLASSE DETECTEE') === -1) {\n    return null; // Ignore les autres lignes (debug, timings...)\n}\n\n// Extraction de la classe après \" : \"\nvar parts = txt.split(' : ');\nif (parts.length < 2) return null;\n\nvar label = parts[parts.length - 1].trim();\n\n// Classes valides (doit correspondre à tes labels Edge Impulse)\nvar validClasses = ['LED', 'Resistance', 'Condensateur', 'CircuitIntegre'];\n\nif (validClasses.indexOf(label) === -1) {\n    node.warn('Classe inconnue reçue : ' + label);\n    return null;\n}\n\nmsg.payload = label;\nmsg.topic   = label;\nreturn msg;",
    "outputs": 1,
    "x": 330,
    "y": 100,
    "wires": [["route_class", "debug_label"]]
  },
  {
    "id": "debug_label",
    "type": "debug",
    "z": "tab_composants",
    "name": "Debug classe",
    "active": true,
    "tosidebar": true,
    "complete": "payload",
    "x": 530,
    "y": 40,
    "wires": []
  },
  {
    "id": "route_class",
    "type": "switch",
    "z": "tab_composants",
    "name": "Router par classe",
    "property": "payload",
    "propertyType": "msg",
    "rules": [
      {"t": "eq", "v": "LED",           "vt": "str"},
      {"t": "eq", "v": "Resistance",    "vt": "str"},
      {"t": "eq", "v": "Condensateur",  "vt": "str"},
      {"t": "eq", "v": "CircuitIntegre","vt": "str"}
    ],
    "checkall": "false",
    "outputs": 4,
    "x": 550,
    "y": 100,
    "wires": [
      ["counter_led"],
      ["counter_resistance"],
      ["counter_condensateur"],
      ["counter_ci"]
    ]
  },
  {
    "id": "counter_led",
    "type": "function",
    "z": "tab_composants",
    "name": "Compteur LED",
    "func": "context.count = (context.count || 0) + 1;\nmsg.payload = context.count;\nmsg.topic = 'LED';\nreturn msg;",
    "outputs": 1,
    "x": 780,
    "y": 60,
    "wires": [["gauge_led", "chart_all"]]
  },
  {
    "id": "counter_resistance",
